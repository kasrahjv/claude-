{
  "manifest_version": 3,
  "name": "Quick Open",
  "version": "1.0.0",
  "description": "Type a website name or link and open it instantly. Save favorites for one-click access.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quick Open"
  },
  "permissions": ["tabs", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
